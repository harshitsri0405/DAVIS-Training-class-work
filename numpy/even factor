import numpy as np

n = int(input("Enter a number: "))

if n == 0:
    print("0 factor of zero is infinite give valid number")
else:
    n = abs(n)  
    
    even_factors = []

    for i in range(1, n+1):
        if n % i == 0 and i % 2 == 0:
            even_factors.append(i)

    arr = np.array(even_factors)
    print("Even factors array:", arr)